	<string>https://lexykon.org/api/v1</string>
	<key>NSUserActivityTypes</key>
	<array>
		<string>com.dictua.viewEntry</string>
	</array>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>ua.dict.ios</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>lexykon</string>
			</array>
			<key>CFBundleRoleEditor</key>
			<string>Viewer</string>
		</dict>
	</array>
</dict>
</plist>
